version: '3.8'

services:
  db:
    build:
      context: ./database
      dockerfile: Dockerfile
    container_name: job_simulator_db
    restart: always
    environment:
      POSTGRES_USER: ${DB_USER:-postgres}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-postgres}
      POSTGRES_DB: ${DB_NAME:-job_simulator}
    ports:
      - "5433:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-postgres} -d ${DB_NAME:-job_simulator}"]
      interval: 5s
      timeout: 5s
      retries: 5

  api:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: job_simulator_api
    restart: always
    ports:
      - "8080:3000"
    environment:
      - PORT=3000
      - DB_HOST=db
      - DB_PORT=5432
      - DB_USER=${DB_USER:-postgres}
      - DB_PASSWORD=${DB_PASSWORD:-postgres}
      - DB_NAME=${DB_NAME:-job_simulator}
    depends_on:
      db:
        # La aplicación no inicia hasta que PostgreSQL esté
        condition: service_healthy

  frontend:
    image: nginx:alpine
    container_name: job_simulator_frontend
    restart: always
    ports:
      - "8088:80"
    volumes:
      - ./frontend/public:/usr/share/nginx/html
    depends_on:
      - api

volumes:
  pgdata:
